        "source_fetched_at": "2026-02-20T19:26:06+00:00",
        "statement_id": "doc::items::unions.md::section:0014::statement:002",
        "statement_text": "As a result, if one field of a union is borrowed, all its remaining fields are borrowed as well for the same lifetime.",
