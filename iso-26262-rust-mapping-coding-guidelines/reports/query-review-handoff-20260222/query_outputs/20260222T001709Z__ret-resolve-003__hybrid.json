        "source_anchor": "https://doc.rust-lang.org/reference/behavior-considered-undefined.html#behavior-considered-undefined",
        "source_fetched_at": "2026-02-20T19:26:06+00:00",
        "statement_id": "doc::behavior-considered-undefined.md::section:0001::statement:009",
        "statement_text": "The exact aliasing rules are not determined yet, but here is an outline of the general principles: `&T` must point to memory that is not mutated while they are live (except for data inside an [`UnsafeCell<U>`]), and `&mut T` must point to memory that is not read or written by any pointer not derived from the reference and that no other reference points to while they are live.",
        "text_sha256": "0e098e98cc0f18a9168a478cee930c8b85790669164edd3c65620a2de7ec2527",
        "token_overlap_count": 0
