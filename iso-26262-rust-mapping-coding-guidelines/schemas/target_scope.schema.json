{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Target Scope",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "in_scope_target_ids"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "in_scope_target_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
