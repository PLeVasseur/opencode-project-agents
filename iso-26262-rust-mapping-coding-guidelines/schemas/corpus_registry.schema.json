{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Corpus Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "default_corpus_pack", "corpus_packs"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "default_corpus_pack": {
      "type": "string",
      "minLength": 1
    },
    "corpus_packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "corpus_pack_id",
          "enabled",
          "extractor_target_parts",
          "seed_manifest_path",
          "default_profile",
          "allowed_modes"
        ],
        "properties": {
          "corpus_pack_id": {
            "type": "string",
            "minLength": 1
          },
          "enabled": {
            "type": "boolean"
          },
          "extractor_target_parts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "seed_manifest_path": {
            "type": "string",
            "minLength": 1
          },
          "default_profile": {
            "type": "string",
            "enum": ["quick", "full"]
          },
          "allowed_modes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["change", "growth"]
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
