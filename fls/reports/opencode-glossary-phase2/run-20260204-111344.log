        RepresentationList ::=
            Representation ($$,$$ Representation)* $$,$$?
     
        Representation ::=
            RepresentationKind
          | Alignment
     
        RepresentationKind ::=
            PrimitiveRepresentation
          | $$C$$
          | $$Rust$$
          | $$transparent$$
     
        Alignment ::=
            AlignmentDecrease
          | AlignmentIncrease
     
        PrimitiveRepresentation ::=
            $$i8$$
