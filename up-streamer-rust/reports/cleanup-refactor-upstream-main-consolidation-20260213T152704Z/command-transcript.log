    ++            claims_path.display()
    ++        );
    ++        assert!(
    ++            loaded
    ++                .claims
    ++                .iter()
    ++                .any(|claim| claim.category == ClaimCategory::StreamerEgress),
    ++            "{} claims file must include streamer egress coverage",
    ++            claims_path.display()
    ++        );
    ++        assert!(
