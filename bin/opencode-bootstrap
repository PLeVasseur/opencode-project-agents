#!/usr/bin/env bash

set -euo pipefail

if ! command -v git >/dev/null 2>&1; then
  echo "opencode-bootstrap: git is required" >&2
  exit 1
fi

root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$root" ]; then
  echo "opencode-bootstrap: not in a git repository" >&2
  exit 1
fi

repo="$(basename "$root")"
base_dir="$HOME/opencode-project-agents"
target_dir="$base_dir/$repo"

template_dir="$base_dir/templates"
template_config="$template_dir/opencode.jsonc"
template_agents="$template_dir/AGENTS.md"

mkdir -p "$target_dir"

needs_config=false
needs_agents=false

if [ ! -f "$target_dir/opencode.jsonc" ]; then
  needs_config=true
fi

if [ ! -f "$target_dir/AGENTS.md" ]; then
  needs_agents=true
fi

if $needs_config && [ ! -f "$template_config" ]; then
  echo "opencode-bootstrap: missing template $template_config" >&2
  exit 1
fi

if $needs_agents && [ ! -f "$template_agents" ]; then
  echo "opencode-bootstrap: missing template $template_agents" >&2
  exit 1
fi

if $needs_config; then
  cp "$template_config" "$target_dir/opencode.jsonc"
  echo "Created $target_dir/opencode.jsonc"
fi

if $needs_agents; then
  cp "$template_agents" "$target_dir/AGENTS.md"
  echo "Created $target_dir/AGENTS.md"
fi
